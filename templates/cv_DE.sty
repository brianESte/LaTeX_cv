\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cv_DE}[2026]

% What to include?
% Advanced lists used in employmentEntry
\RequirePackage{enumitem}
\RequirePackage{pgffor}

\RequirePackage{etoolbox}
% TikZ for stars
\RequirePackage{tikz}
\usetikzlibrary{
	calc,
	shapes.geometric
}
\newcommand{\starFilled}{%
	\begin{tikzpicture}[scale=0.4, transform shape]
		\node [star, star point height=2.9mm, minimum size=10mm, fill] {};
	\end{tikzpicture}
}
\newcommand{\starHollow}{%
	\begin{tikzpicture}[scale=0.4, transform shape]
		\node [star, star point height=2.9mm, minimum size=10mm, draw] {};
	\end{tikzpicture}
}

%% Section header
\newcommand{\Section}[1]{\section*{\textcolor{gray}{\textbf{#1}}}}

% Create name command, and internal name command
\newcommand*{\name}[1]{\gdef\@name{#1}}
\newcommand*{\@name}{$\langle$\texttt{Name}$\rangle$}
% Birthday commands
\newcommand*{\birthday}[1]{\gdef\@birthday{#1}}
\newcommand*{\@birthday}{$\langle$\texttt{Geburtsdatum}$\rangle$}
\newcommand*{\birthplace}[1]{\gdef\@birthplace{#1}}
\newcommand*{\@birthplace}{$\langle$\texttt{Geburtsort}$\rangle$}
% Nationality command
\newcommand*{\nationality}[1]{\gdef\@nationality{#1}}
\newcommand*{\@nationality}{$\langle$\texttt{Staatsangehörigkeit}$\rangle$}
% Family status command
\newcommand*{\familyStatus}[1]{\gdef\@familyStatus{#1}}
\newcommand*{\@familyStatus}{$\langle$\texttt{Familienstand}$\rangle$}
% Create address command
\newcommand*{\address}[2]{\gdef\@address{#1\newline#2}}
\newcommand*{\@address}{$\langle$\texttt{Straße}$\rangle$\newline$\langle$\texttt{Wohnort}$\rangle$}
% Create phone[number] command
\newcommand*{\phone}[1]{\gdef\@phone{#1}}
\newcommand*{\@phone}{$\langle$\texttt{Mobilnummer}$\rangle$}
% Create email [address] command
\newcommand*{\email}[1]{\gdef\@email{#1}}
\newcommand*{\@email}{$\langle$\texttt{E-Mail-Adresse}$\rangle$}

\renewcommand*{\maketitle}{
\Section{Persönliche Daten}
% table with 2 cols next to an image
\newsavebox{\tableBox}%
\newlength{\tableHeight}%
% https://tex.stackexchange.com/questions/66426/tabular-height-savebox-problem/66429#66429
\savebox{\tableBox}[0.562\textwidth]{%
	\vspace{3pt}%
	\large
	\begin{tabular}[b]{l p{6cm}}
		Name & \@name \\
		Geburtsdatum & \@birthday \\
		Geburtsort & \@birthplace \\
		Staatsangehörigkeit & \@nationality \\
		Familienstand & \@familyStatus \\
		Anschrift & \@address \\
		Mobil & \@phone \\
		Mail & \@email \\
		LinkedIn & www.linkedin.com/in/...
	\end{tabular}
}%
\settoheight{\tableHeight}{\usebox{\tableBox}}
\usebox{\tableBox}%
\hfil
\includegraphics[height=\tableHeight]{../res/beige_wall_cropped.jpg}
}


%% Education entry
% School, date, degree, GPA
\newcommand{\educationEntry}[4]{\par\noindent\large\underline{#1}\par\noindent #2\hfill#3\hspace{10mm}#4\bigskip}

%% Employment entry
% Position, organization, location, duration(s), responsibilities
\NewDocumentCommand{\employmentEntry}{m m d[] m m}{%
	\parbox{\textwidth}{\large
		\IfValueTF{#3}{%
			\par\noindent\underline{#2, #3} #1%
		}{%
			\par\noindent\underline{#2} #1%
		}
	\par
	\begin{minipage}{0.19\textwidth}
		\begin{itemize}[noitemsep,nolistsep,leftmargin=0pt]
		% https://stackoverflow.com/a/3281778
			\foreach \dateEntry in {#4}{
				\item[] \dateEntry
			}
		\end{itemize}
	\end{minipage}
	\hfil
	\begin{minipage}{0.80\textwidth}
		\begin{itemize}[noitemsep,nolistsep]
			\foreach \task in {#5}{
				\item \task
			}
		\end{itemize}
	\end{minipage}
	\bigskip
}}

% Helper functions to print filled/hollow shapes
\newcommand{\printFilled}[2]{\foreach \i in {1,...,#1} {#2}}
% NOTE: fn nHollow will display stars even if arg1=5
\newcommand{\printHollow}[2]{%
	\pgfmathtruncatemacro{\n}{5-#1}%
	\foreach \i in {1,...,\n} {#2}%
}

%% Count the number of items in a list
\newcommand{\countItems}[1]{%
	\newcounter{c}%
	\foreach \i in {#1}{\stepcounter{c}}%
	\thec%
}

% NOTE: it is possible to split arguments with NewDocumentCommand,
% but it is easier with \def
\def\skillListEntry#1,#2,#3,#4!{#1 & \printFilled{#2}{#3}\printHollow{#2}{#4}\\}

%% Skill list
% List title, list of skills (name-lvl pairs), filled symbol, hollow symbol
\newcommand{\skillList}[4]{%
	%\countItems{#1}
	% NOTE: renew-do must be outside of tabular environment,
	% otherwise only the first item in the list will be processed
	\renewcommand*{\do}[1]{\skillListEntry##1,#3,#4!}
	% \renewcommand*{\do}[1]{\skillListEntry##1!}
\begin{tabular}{ll}
	\multicolumn{2}{l}{#1} \\
	\hline
	% NOTE: For info on \docsvlist, see
	% https://ctan.net/macros/latex/contrib/etoolbox/etoolbox.pdf
	\docsvlist{#2}
\end{tabular}
}

